{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-svelte-template",
  "version": "0.0.1",
  "identifier": "com.tauri-svelte-template.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1620",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tauri Svelte Template",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
